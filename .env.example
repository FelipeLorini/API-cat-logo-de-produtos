# String de conexão com o MongoDB (local ou Atlas)
MONGODB_URI=mongodb://localhost:27017/catalogo_produtos

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=seu_segredo_super_secreto_aqui

# Tempo de expiração do token JWT (ex: 1d, 7d, 2h)
JWT_EXPIRES_IN=7d

# Porta em que o servidor vai rodar
PORT=3000

# Ambiente de execução (development | production)
NODE_ENV=development
